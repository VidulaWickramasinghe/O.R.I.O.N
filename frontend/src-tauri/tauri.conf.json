{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "O.R.I.O.N. Aurora OS",
  "version": "3.5.0",
  "identifier": "com.orion.auroraos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "O.R.I.O.N. Aurora OS",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
